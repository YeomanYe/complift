{
  "name": "extension",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "copy-wasm": "node scripts/copy-esbuild-wasm.mjs",
    "dev": "pnpm run copy-wasm && wxt",
    "build": "pnpm run copy-wasm && wxt build",
    "zip": "pnpm run copy-wasm && wxt zip",
    "postinstall": "node scripts/copy-esbuild-wasm.mjs && wxt prepare",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.5",
    "@uiw/react-codemirror": "^4.25.10",
    "esbuild-wasm": "^0.28.1",
    "idb": "^8.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@wxt-dev/module-react": "^1.2.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wxt": "^0.20.26"
  }
}
